<?php
$host = 'localhost';
$user = 'root';
$pass = '';
$db   = 'selemogo_db';

$conn = mysqli_connect($host, $user, $pass, $db);
if (!$conn) {
    die('Connection failed: ' . mysqli_connect_error());
}

ini_set("session.cookie_path", "/");
session_save_path("/tmp");
session_start();

function clean($data) {
    $data = trim($data);
    $data = stripslashes($data);
    $data = htmlspecialchars($data);
    return $data;
}
?>
